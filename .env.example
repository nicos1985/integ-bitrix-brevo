# ── Django ──────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=app.tudominio.com

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/bitrix_brevo

# ── Encryption ───────────────────────────────────────────────────────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=base64-fernet-key-here

# ── Bitrix24 ─────────────────────────────────────────────────────────
BITRIX_APP_CLIENT_ID=local.xxxxxxxxxxxxx
BITRIX_APP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BITRIX_APPLICATION_TOKEN=optional-application-token
# Public HTTPS base URL of this app (no trailing slash)
BITRIX_APP_BASE_URL=https://app.tudominio.com

# ── Brevo ────────────────────────────────────────────────────────────
# Default webhook secret used for testing; override per BrevoAccount in DB
BREVO_DEFAULT_WEBHOOK_SECRET=change-me

# ── Observability ────────────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=
